# Boatwork API integration
BOATWORK_API_TOKEN=        # Boatwork API bearer token (for authenticated endpoints)
BOATWORK_WEBHOOK_SECRET=   # Secret for verifying Boatwork webhook signatures

# Cron & revalidation
CRON_SECRET=               # Secret for authenticating cron/sync calls
REVALIDATE_SECRET=         # Next.js on-demand revalidation secret

# AI content generation (pre-build script only — NOT needed in Vercel)
# Used by: node scripts/generate-content.mjs (run before `vercel deploy`)
# BOATWORK_PROFILE_SLUG and ANTHROPIC_API_KEY must be set in the orchestration
# environment where the pre-build script runs, not in Vercel's env vars.
BOATWORK_PROFILE_SLUG=     # Contractor profile slug (e.g. yachts-etc)
ANTHROPIC_API_KEY=         # Anthropic API key — only for the pre-build script

# Site
NEXT_PUBLIC_SITE_URL=      # Full URL of deployed site (e.g. https://yachtsetc.boatwork.co)

# Email (contact form)
RESEND_API_KEY=            # Resend API key for transactional email
